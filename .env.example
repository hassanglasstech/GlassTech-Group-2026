# ─────────────────────────────────────────────────────────────────────────────
# GlassTech ERP 2026 — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git or include it in ZIP distributions.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (required for cloud sync)
# Get these from: https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Gemini AI (required for NipponSmartImporter PDF parsing)
# Get this from: https://aistudio.google.com/apikey
# ⚠️  This key is injected into the browser bundle by Vite.
#     Move the Gemini call to a backend proxy (server.ts) before going to production.
GEMINI_API_KEY=your-gemini-key-here
