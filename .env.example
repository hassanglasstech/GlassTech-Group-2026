# .env.example — frontend only (never put secrets here)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Feature flags ──
VITE_USE_EDGE_FUNCTIONS=true

# ── Supabase Edge Function secrets (set in Supabase Dashboard → Settings → Secrets) ──
# ANTHROPIC_API_KEY=          Claude API key (claude-haiku-4-5-20251001 + claude-sonnet-4-6)
# GEMINI_API_KEY=             Google Gemini API key (used by gemini-proxy only — optional fallback)
# OPENAI_API_KEY=             Whisper transcription (whatsapp-intelligence)
# SITE_URL=                   Production Vercel URL e.g. https://glasstech-erp.vercel.app
# CRON_SECRET=                Random secret for authenticating cron job triggers
# TELEGRAM_BOT_TOKEN=         From BotFather
# TELEGRAM_CHAT_ID=           Your personal Telegram chat ID
# TELEGRAM_WEBHOOK_SECRET=    Random secret set when registering the Telegram webhook
# WA_PHONE_NUMBER_ID=         WhatsApp Business phone number ID
# WA_ACCESS_TOKEN=            WhatsApp Business permanent access token
# WA_TO_NUMBER=               Recipient number e.g. 923001234567
# WA_WEBHOOK_SECRET=          HMAC secret set in Meta WhatsApp webhook config
