# Integration-test env — points at the LOCAL Supabase stack (Docker).
# Copy to .env.test (gitignored). Get the real values from `supabase start`
# output ("API URL", "anon key", "service_role key"). The defaults below are
# the standard Supabase local demo keys and work with a default local stack.
#
#   1) Install Docker Desktop
#   2) npm run supabase:start        (or: npx supabase start)
#   3) cp .env.test.example .env.test  and paste the printed keys if different
#   4) npm run test:integration

SUPABASE_TEST_URL=http://127.0.0.1:54321
